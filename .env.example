# ==============================
# TELKO.STORE — Environment Variables
# Copy to .env.local and fill in values
# ==============================

# Database (MySQL)
DATABASE_URL=mysql://user:password@localhost:3306/telkostore

# Midtrans Sandbox
MIDTRANS_SERVER_KEY=SB-Mid-server-XXXXXXXXXXXXXXXXXXXXXXXX
MIDTRANS_CLIENT_KEY=SB-Mid-client-XXXXXXXXXXXXXXXXXXXXXXXX
MIDTRANS_IS_PRODUCTION=false
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=SB-Mid-client-XXXXXXXXXXXXXXXXXXXXXXXX

# Pakasir (Payment Gateway)
PAKASIR_API_KEY=your-pakasir-api-key
PAKASIR_PROJECT_SLUG=your-project-slug
PAKASIR_IS_PRODUCTION=false
PAKASIR_API_URL=https://app.pakasir.com

# WAHA (WhatsApp API)
WAHA_API_URL=http://localhost:3002
WAHA_SESSION=default
WAHA_API_KEY=
WAHA_GROUP_ID=

# Control Panel / Admin
ADMIN_SECRET=change-me-long-random-secret
ADMIN_LOGIN_USER=admin
ADMIN_LOGIN_EMAIL=admin@telko.store
ADMIN_LOGIN_PASSWORD=change-me-strong-password
ADMIN_DEFAULT_USER_PASSWORD=telko.store@2026

# App
NEXT_PUBLIC_BASE_URL=https://telko.store

# Auth.js (NextAuth)
AUTH_SECRET=change-me-random-32-chars
AUTH_TRUST_HOST=true
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
