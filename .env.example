# ==============================
# TELKO.STORE — Environment Variables
# Copy to .env.local and fill in values
# ==============================

# Database (SQLite - file path relative to project root)
DATABASE_URL=file:./telko.db

# Midtrans Sandbox
MIDTRANS_SERVER_KEY=SB-Mid-server-XXXXXXXXXXXXXXXXXXXXXXXX
MIDTRANS_CLIENT_KEY=SB-Mid-client-XXXXXXXXXXXXXXXXXXXXXXXX
MIDTRANS_IS_PRODUCTION=false
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=SB-Mid-client-XXXXXXXXXXXXXXXXXXXXXXXX

# WAHA (WhatsApp API)
WAHA_API_URL=http://localhost:3002
WAHA_SESSION=default
WAHA_API_KEY=
WAHA_GROUP_ID=

# Admin
ADMIN_SECRET=change-me-min-8-chars

# App
NEXT_PUBLIC_BASE_URL=https://telko.store

# Auth.js (NextAuth)
AUTH_SECRET=change-me-random-32-chars
AUTH_TRUST_HOST=true
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
